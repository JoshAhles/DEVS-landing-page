---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden"
>
  <div
    class="absolute inset-0 grid-tech opacity-25"
    aria-hidden="true"
  />
  <div
    class="absolute inset-0 pointer-events-none z-[1] grid-tech grid-wave-on-lines"
    aria-hidden="true"
  />
  <div
    class="absolute -top-24 right-[-20%] h-72 w-72 rounded-full blur-3xl bg-[var(--color-accent)]/20 orb-float-slow"
    aria-hidden="true"
  />
  <div
    class="absolute -bottom-28 left-[-10%] h-72 w-72 rounded-full blur-3xl bg-[var(--color-accent-2)]/12 orb-float-fast"
    aria-hidden="true"
  />

  <div class="relative max-w-5xl mx-auto text-center anime-hero-pending" data-hero-content>
    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl tracking-tight text-white leading-tight">
      Never coded before?<br />
      That first dev job <span class="text-[var(--color-accent)] neon-glow">starts here.</span>
    </h1>

    <p class="mt-7 text-lg sm:text-xl copy-muted max-w-2xl mx-auto leading-relaxed">
      Start from zero. Level up into the skills real teams expect on the job.
    </p>

    <div class="mt-10">
      <a
        href="#notify"
        class="btn-primary cta-glow"
      >
        Join early access <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>
