---
---

<div class="text-center">
  <span class="eyebrow">Access</span>
  <h2 class="mt-5 text-2xl sm:text-3xl font-bold tracking-tight text-white">
    Simple, transparent pricing
  </h2>

  <div class="mt-12 max-w-md mx-auto">
    <div class="surface-card p-10 card-hover-depth">
      <!-- Price highlight -->
      <div class="inline-block mb-6">
        <div class="text-5xl font-display text-[var(--color-accent)] font-bold">Free</div>
        <p class="text-xs copy-subtle mt-1">For early access</p>
      </div>

      <!-- Description -->
      <p class="text-base copy-muted mb-8 leading-relaxed">
        DEVS is practical, non-accredited training focused on job-ready skills. Access is currently free while we grow the program.
      </p>

      <!-- Features list -->
      <div class="space-y-3 mb-8 text-left">
        <div class="flex items-start gap-3">
          <span class="text-[var(--color-accent-2)] font-bold mt-0.5">✓</span>
          <span class="text-sm copy-muted">Full access to hands-on labs</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-[var(--color-accent-2)] font-bold mt-0.5">✓</span>
          <span class="text-sm copy-muted">Real environment setup</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-[var(--color-accent-2)] font-bold mt-0.5">✓</span>
          <span class="text-sm copy-muted">Career mentorship path</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-[var(--color-accent-2)] font-bold mt-0.5">✓</span>
          <span class="text-sm copy-muted">Community support</span>
        </div>
      </div>

      <!-- CTA Button -->
      <a href="#notify" class="btn-primary cta-glow w-full block text-center mb-4">
        Join early access <span aria-hidden="true">&rarr;</span>
      </a>

      <!-- Footer note -->
      <p class="text-xs copy-subtle">*Subject to change.</p>
    </div>
  </div>

  <!-- Value proposition note -->
  <div class="mt-12 max-w-md mx-auto">
    <p class="text-sm copy-muted">
      <span class="text-[var(--color-accent)] font-semibold">Why free?</span> We're building the platform. Early access members help us perfect the curriculum for future developers.
    </p>
  </div>
</div>
