---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import TrustSection from "../components/TrustSection.astro";
import Section from "../components/Section.astro";
import ValueProps from "../components/ValueProps.astro";
import NotVibeSection from "../components/NotVibeSection.astro";
import WhyDEVS from "../components/WhyDEVS.astro";
import FeaturesGrid from "../components/FeaturesGrid.astro";
import PortfolioShowcase from "../components/PortfolioShowcase.astro";
import ProcessTimeline from "../components/ProcessTimeline.astro";
import Testimonials from "../components/Testimonials.astro";
import LabTeaserEnhanced from "../components/LabTeaserEnhanced.astro";
import PricingEnhanced from "../components/PricingEnhanced.astro";
import CtaSection from "../components/CtaSection.astro";
---

<Layout title="DEVS | Beginner to team-ready software developer training">
  <main id="main">
    <!-- Hero with maximum impact -->
    <Hero />

    <!-- Trust building with animated stats -->
    <Section id="trust" narrow extraTopPadding spacingVariant="spacious" accentColor="cyan" bgVariant="gradient">
      <TrustSection />
    </Section>

    <!-- Value propositions - what makes DEVS different -->
    <Section id="value-props" dark spacingVariant="normal" accentColor="green" bgVariant="dark">
      <ValueProps />
    </Section>

    <!-- School-to-team gap narrative -->
    <Section id="why-devs" dark spacingVariant="normal" accentColor="cyan" bgVariant="gradient">
      <WhyDEVS />
    </Section>

    <!-- Curriculum features - separated from value props -->
    <Section id="what-we-teach" spacingVariant="compact" accentColor="green" bgVariant="light">
      <FeaturesGrid />
    </Section>

    <!-- Portfolio building - what you'll ship -->
    <Section id="portfolio" spacingVariant="spacious" accentColor="cyan" bgVariant="gradient">
      <PortfolioShowcase />
    </Section>

    <!-- Why DEVS is different - narrative context -->
    <Section id="not-vibe" dark spacingVariant="normal" accentColor="cyan" bgVariant="dark">
      <NotVibeSection />
    </Section>

    <!-- 4-step process timeline -->
    <Section id="how-it-works" spacingVariant="spacious" accentColor="green" bgVariant="light">
      <ProcessTimeline />
    </Section>

    <!-- Social proof - testimonials carousel -->
    <Section id="testimonials" dark spacingVariant="normal" accentColor="cyan" bgVariant="dark">
      <Testimonials />
    </Section>

    <!-- Lab environment showcase -->
    <Section id="lab" spacingVariant="spacious" accentColor="green" bgVariant="light">
      <LabTeaserEnhanced />
    </Section>

    <!-- Enhanced pricing with benefits -->
    <Section id="pricing" dark spacingVariant="normal" accentColor="cyan" bgVariant="dark">
      <PricingEnhanced />
    </Section>

    <!-- Final CTA and founder bio -->
    <Section id="cta-section" dark spacingVariant="extra" accentColor="green" bgVariant="light">
      <CtaSection />
    </Section>
  </main>
</Layout>
